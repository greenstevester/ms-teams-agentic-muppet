node_modules/
dist/
.env
.env.local
*.log
.DS_Store

# Override the global *.lock rule — bun.lock is committed for reproducible builds.
!bun.lock

# Per-thread agent sandboxes — ephemeral, never commit
workspaces/

# But do commit the directory marker
!workspaces/.gitkeep

# Channel and user memory created at runtime is fine to commit;
# do NOT commit the workspaces though.
