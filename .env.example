# --- Claude Agent SDK backend (pick ONE) ---

# === Path A: AWS Bedrock (recommended) ===
#
# One-time host setup (do this on WSL / your dev machine):
#   1. Install AWS CLI v2 — https://docs.aws.amazon.com/cli/latest/userguide/getting-started-install.html
#   2. Run `aws configure sso` (for SSO) or `aws configure` (for static keys)
#   3. Verify: `aws sts get-caller-identity --profile <your-profile>`
#
# docker-compose.yml bind-mounts ~/.aws read-only, so creds + SSO token cache
# flow into the container automatically. Just set these:
CLAUDE_CODE_USE_BEDROCK=1
AWS_PROFILE=default
AWS_REGION=us-east-1

# Bedrock model ID or inference profile ARN. Discover what's available with:
#   aws bedrock list-foundation-models --region us-east-1 --by-provider anthropic
# Example shape: anthropic.claude-opus-4-...:0  (exact value depends on region)
ANTHROPIC_MODEL=

# === Path B: Direct Anthropic API (no AWS account needed) ===
#
# Use this if you don't have Bedrock access yet. Comment out Path A above.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-7

# --- Microsoft Teams (leave blank to use the Bot Framework Emulator locally) ---
# Filled in only after you register an Azure Bot resource — see "Setting up
# real Teams" in README.md.
MS_APP_ID=
MS_APP_PASSWORD=
MS_APP_TYPE=MultiTenant
MS_APP_TENANT_ID=

# --- Cloudflare Tunnel (only when graduating from Emulator to real Teams) ---
# Enable with `docker compose --profile tunnel up`
CF_TUNNEL_TOKEN=
