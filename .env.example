# --- Claude Agent SDK backend (pick ONE) ---

# === Path A: AWS Bedrock (recommended) ===
#
# AWS CLI v2 is installed inside the container — you do NOT need it on the host.
#
# One-time SSO setup (interactive; opens a browser URL on your host):
#   docker compose run --rm ms-teams-agentic-muppet aws configure sso
#
# Verify:
#   docker compose run --rm ms-teams-agentic-muppet aws sts get-caller-identity
#
# Refresh expired SSO token later:
#   docker compose exec ms-teams-agentic-muppet aws sso login
#
# Credentials persist in the `aws-creds` Docker named volume across restarts
# and rebuilds. Only `docker compose down -v` wipes them.
CLAUDE_CODE_USE_BEDROCK=1
AWS_PROFILE=default
AWS_REGION=us-east-1

# Bedrock model ID or inference profile ARN. Discover what's available with:
#   docker compose exec ms-teams-agentic-muppet aws bedrock list-foundation-models \
#       --region us-east-1 --by-provider anthropic
# Example shape: anthropic.claude-opus-4-...:0  (exact value depends on region)
ANTHROPIC_MODEL=

# === Path B: Direct Anthropic API (no AWS account needed) ===
#
# Use this if you don't have Bedrock access yet. Comment out Path A above.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-7

# --- Microsoft Teams (leave blank to use the Bot Framework Emulator locally) ---
# Filled in only after you register an Azure Bot resource — see "Setting up
# real Teams" in README.md.
MS_APP_ID=
MS_APP_PASSWORD=
MS_APP_TYPE=MultiTenant
MS_APP_TENANT_ID=

# --- Cloudflare Tunnel (only when graduating from Emulator to real Teams) ---
# Enable with `docker compose --profile tunnel up`
CF_TUNNEL_TOKEN=
