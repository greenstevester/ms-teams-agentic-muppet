# --- Local development (Bot Framework Emulator) ---
# Required for the Claude Agent SDK to reach a model via LiteLLM → OpenRouter
OPENROUTER_API_KEY=sk-or-...

# --- Real Teams (graduating from Emulator) ---
# Created when you register an Azure Bot resource
MS_APP_ID=
MS_APP_PASSWORD=
MS_APP_TYPE=MultiTenant
MS_APP_TENANT_ID=

# --- Cloudflare Tunnel (only when using real Teams) ---
# `docker compose --profile tunnel up` to enable
CF_TUNNEL_TOKEN=
