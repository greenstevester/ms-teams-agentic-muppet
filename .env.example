# --- Claude Agent SDK backend (pick ONE) ---

# Path A: Direct Anthropic API. Easiest for local dev.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model. Defaults to claude-opus-4-7 in docker-compose.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Path B: AWS Bedrock. Use for production.
# Uncomment and fill in. Leave Path A blank when using Bedrock.
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# When using Bedrock, set ANTHROPIC_MODEL to your Bedrock model ID or
# inference profile ARN (the exact value depends on your account/region).
# ANTHROPIC_MODEL=

# --- Microsoft Teams (real Teams; leave blank for Bot Framework Emulator) ---
# Created when you register an Azure Bot resource.
MS_APP_ID=
MS_APP_PASSWORD=
MS_APP_TYPE=MultiTenant
MS_APP_TENANT_ID=

# --- Cloudflare Tunnel (only when using real Teams) ---
# `docker compose --profile tunnel up` to enable
CF_TUNNEL_TOKEN=
